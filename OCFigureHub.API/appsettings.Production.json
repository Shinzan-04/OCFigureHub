{
  "ConnectionStrings": {
    "DefaultConnection": "#{DB_CONNECTION_STRING}#"
  },
  "Jwt": {
    "Issuer": "OCFigureHub",
    "Audience": "OCFigureHubClient",
    "Key": "#{JWT_SECRET_KEY}#",
    "ExpireMinutes": 1440
  },
  "AzureBlob": {
    "ConnectionString": "#{AZURE_STORAGE_CONNECTION_STRING}#",
    "ContainerName": "product-files",
    "SasExpireMinutes": 5
  },
  "VNPay": {
    "TmnCode": "#{VNPAY_TMN_CODE}#",
    "HashSecret": "#{VNPAY_HASH_SECRET}#",
    "BaseUrl": "https://pay.vnpay.vn/vpcpay.html",
    "ReturnUrl": "https://#{YOUR_DOMAIN}#/vnpay-return",
    "IpnUrl": "https://api.#{YOUR_DOMAIN}#/api/payments/vnpay-ipn"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:80"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
